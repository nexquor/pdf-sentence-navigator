{
  "manifest_version": 3,
  "name": "PDF Sentence Navigator",
  "version": "1.1",
  "description": "Navigate PDF sentences locally using TAB and SHIFT+TAB. Automatically intercepts PDFs opened in Chrome.",
  "permissions": [
    "webNavigation"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "Open PDF Viewer"
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["viewer.html", "viewer.js", "pdf.min.js", "pdf.worker.min.js"],
      "matches": ["<all_urls>"]
    }
  ]
}